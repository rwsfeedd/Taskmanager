<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.javafx.terminmanagement.Controllers.TaskOverviewController">
    <center>
        <ListView fx:id="taskList"/>
    </center>
    <right>
        <VBox>
            <Button text="Aufgabe erstellen" onAction="#onTaskCreateButtonClick"/>
            <Button text="Aufgabe löschen" onAction="#onTaskDeleteButtonClick"/>
            <Button text="Aufgabe eintragen" onAction="#onTaskSignInButtonClick"/>
            <Button text="zurück" onAction="#onReturnButtonClick"/>
        </VBox>
    </right>
</BorderPane>
