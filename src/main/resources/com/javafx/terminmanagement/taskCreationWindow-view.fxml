<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.javafx.terminmanagement.Controllers.TaskCreationController">
    <left>
        <Label fx:id="welcomeText"/>
    </left>
    <center>
        <Label text="taskCreationWindow"/>
    </center>
    <right>
        <VBox>
            <Button text="Aufgabe erstellen" onAction="#onTaskCreateButtonClick"/>
            <Button text="Abbrechen" onAction="#onCancelButtonClick"/>
        </VBox>
    </right>
</BorderPane>
